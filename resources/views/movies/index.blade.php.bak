@section('scripts')
<script>
(function () {
    var currentPage  = 1;
    var totalPages   = {{ isset($totalPages) ? (int)$totalPages : 1 }};
    var searchQuery  = @json($query);
    var searchType   = @json($type);
    var searchYear   = @json($year);
    var defaultYear  = @json($defaultYear ?? null);
    var defaultTerm  = @json($defaultTerm ?? null);  // server-chosen term for latest movies
    var isDefault    = {{ $isDefault ? 'true' : 'false' }};
    var loading      = false;
    var favUrl      = '{{ route("favorites.store") }}';
    var unfavBase   = '{{ url("/favorites") }}';
    var csrf        = '{{ csrf_token() }}';

    /* ── Spinner HTML ── */
    $('#loading-spinner .spinner-dots').html('<span></span><span></span><span></span>');

    /* ── Fav Toggle ── */
    $(document).on('click', '.fav-btn', function (e) {
        e.preventDefault();
        var btn    = $(this);
        var imdbId = btn.data('imdb');
        var isFav  = btn.hasClass('is-favorited');

        if (isFav) {
            $.ajax({ url: unfavBase + '/' + imdbId, type: 'POST', data: { _method: 'DELETE', _token: csrf },
                success: function (r) {
                    btn.removeClass('is-favorited bg-accent text-white shadow-md shadow-accent/30')
                       .addClass('bg-white/5 text-gray-500 hover:bg-accent/15 hover:text-accent');
                    btn.find('i').removeClass('fas').addClass('far');
                    showToast(r.message || '{{ __("app.removed_from_favorites") }}', 'success');
                },
                error: function () { showToast('Error', 'error'); }
            });
        } else {
            $.ajax({ url: favUrl, type: 'POST',
                data: { _token: csrf, imdb_id: imdbId, title: btn.data('title'), year: btn.data('year'), poster: btn.data('poster'), type: btn.data('type') },
                success: function (r) {
                    btn.addClass('is-favorited bg-accent text-white shadow-md shadow-accent/30')
                       .removeClass('bg-white/5 text-gray-500 hover:bg-accent/15 hover:text-accent');
                    btn.find('i').removeClass('far').addClass('fas');
                    showToast(r.message || '{{ __("app.added_to_favorites") }}', 'success');
                },
                error: function (xhr) {
                    var msg = (xhr.responseJSON && xhr.responseJSON.message) ? xhr.responseJSON.message : 'Error';
                    showToast(msg, 'error');
                }
            });
        }
    });

    /* ── Build card for AJAX pages ── */
    function buildCard(m) {
        var poster  = (m.Poster && m.Poster !== 'N/A') ? m.Poster : '';
        var isFav   = !!m.is_favorited;
        var type    = (m.Type || 'movie').toLowerCase();
        var typeLabel = type.charAt(0).toUpperCase() + type.slice(1);
        var typeClass = type === 'series'  ? 'bg-blue-500/20 text-blue-300 border-blue-500/30'
                      : type === 'episode' ? 'bg-purple-500/20 text-purple-300 border-purple-500/30'
                      : 'bg-pink-500/15 text-pink-300 border-pink-500/30';
        var favCls  = isFav ? 'is-favorited bg-accent text-white shadow-md shadow-accent/30'
                            : 'bg-white/5 text-gray-500 hover:bg-accent/15 hover:text-accent';
        var heart   = isFav ? 'fas' : 'far';
        var url     = '/movies/' + m.imdbID;
        var img     = poster
            ? '<img class="movie-card-img lazy absolute inset-0 w-full h-full object-cover" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" data-src="' + poster + '" alt="">'
            : '<div class="absolute inset-0 bg-[#12121a] flex items-center justify-center text-gray-700 text-5xl"><i class="fas fa-film"></i></div>';
        return '<div class="movie-card bg-[#16161f] border border-white/5 rounded-xl overflow-hidden flex flex-col group" data-imdb="' + m.imdbID + '">'
            + '<a href="' + url + '" class="block relative overflow-hidden" style="aspect-ratio:2/3;">'
            + img
            + '<div class="absolute bottom-0 inset-x-0 h-1/3 bg-gradient-to-t from-[#16161f] to-transparent pointer-events-none"></div></a>'
            + '<div class="p-3 flex flex-col gap-1.5 flex-1">'
            + '<div class="flex items-center justify-between gap-1">'
            + '<span class="inline-flex items-center text-[10px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded-md border ' + typeClass + '">' + typeLabel + '</span>'
            + '<button class="fav-btn w-7 h-7 flex items-center justify-center rounded-lg transition-all ' + favCls + '"'
            + ' data-imdb="' + m.imdbID + '" data-title="' + (m.Title||'').replace(/"/g,'&quot;') + '"'
            + ' data-year="' + (m.Year||'') + '" data-poster="' + poster + '" data-type="' + type + '">'
            + '<i class="' + heart + ' fa-heart text-xs"></i></button></div>'
            + '<a href="' + url + '" class="block"><h3 class="text-sm font-semibold text-gray-100 leading-snug line-clamp-2 group-hover:text-[#e94560] transition-colors">' + (m.Title||'') + '</h3></a>'
            + '<span class="text-xs text-gray-600">' + (m.Year||'') + '</span>'
            + '</div></div>';
    }

    /* ── Load More ── */
    function loadMore() {
        if (loading || currentPage >= totalPages) return;
        loading = true;
        $('#loading-spinner').removeClass('hidden');
        // When showing default (latest) movies, pass the server-chosen term+year for consistent pagination
        var reqQuery = isDefault ? (defaultTerm || '') : searchQuery;
        var reqYear  = searchYear || (isDefault ? defaultYear : '');
        $.get('{{ route("movies.load-more") }}', { query: reqQuery, type: searchType, year: reqYear, defaultTerm: defaultTerm, defaultYear: defaultYear, page: currentPage + 1 })
            .done(function (data) {
                if (data.success && data.movies && data.movies.length) {
                    currentPage++;
                    $.each(data.movies, function (i, m) { $('#movies-grid').append(buildCard(m)); });
                    initLazyLoad();
                    if (currentPage >= totalPages) $('#scroll-sentinel').remove();
                }
            })
            .always(function () { loading = false; $('#loading-spinner').addClass('hidden'); });
    }

    /* ── Infinite Scroll ── */
    var sentinel = document.getElementById('scroll-sentinel');
    if (sentinel && totalPages > 1) {
        new IntersectionObserver(function (entries) {
            entries.forEach(function (e) { if (e.isIntersecting) loadMore(); });
        }, { rootMargin: '300px' }).observe(sentinel);
    }

    initLazyLoad();
})();
</script>
@endsection